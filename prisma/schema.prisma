// ============================================================
// GOD VIEW — E-DIRECTIVES, KILL SWITCH, AUDIT
// ============================================================

model EDirective {
  id          String          @id @default(cuid())
  authorId    String
  sectorId    String?
  titleEn     String
  titleAr     String?
  bodyEn      String          @db.Text
  bodyAr      String?         @db.Text
  priority    SLAPriority     @default(normal)
  status      DirectiveStatus @default(active)
  targetType  String          @default("all")
  targetIds   Json?
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())

  author User                      @relation(fields: [authorId], references: [id])
  sector Sector?                   @relation(fields: [sectorId], references: [id])
  acks   EDirectiveAcknowledgment[]

  @@index([status])
  @@map("e_directives")
}

model EDirectiveAcknowledgment {
  id          String   @id @default(cuid())
  directiveId String
  userId      String
  ipAddress   String?
  geolocation Json?
  ackedAt     DateTime @default(now())

  directive EDirective @relation(fields: [directiveId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@unique([directiveId, userId])
  @@map("e_directive_acknowledgments")
}

model KillSwitchLog {
  id            String   @id @default(cuid())
