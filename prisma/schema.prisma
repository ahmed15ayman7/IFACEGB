  signatures    Json
  activatedAt   DateTime @default(now())
  deactivatedAt DateTime?
  deactivatedBy String?

  @@map("kill_switch_logs")
}

model AuditTrail {
  id           String        @id @default(cuid())
  userId       String?
  action       String
  entityType   String
  entityId     String?
  severity     AuditSeverity @default(info)
  beforeJson   Json?
  afterJson    Json?
  ipAddress    String?
  userAgent    String?
  encryptedSig String?       @db.Text
  metadata     Json?
  createdAt    DateTime      @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([severity])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_trail")
}

model OffHoursAccessLog {
